# Backend environment example
# Copy this file to `.env` inside `backend/` for local development.

PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-in-local-and-production
JWT_EXPIRES_IN=1d

# Prisma / PostgreSQL
# Planned standard for the future persistence layer.
# Keep this variable name even before the database integration is enabled.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/queplan?schema=public"
