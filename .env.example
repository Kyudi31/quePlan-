# Shared project environment example
# Copy values from here into the env file required by each app.

# Server
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=change-this-in-local-and-production
JWT_EXPIRES_IN=1d

# Future Prisma/PostgreSQL convention
# Not wired end-to-end yet, but this is the standard the team should keep.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/queplan?schema=public"
